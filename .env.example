# Database Settings
# Set DB_HOST to 'localhost' or 'db' to enable PostgreSQL.
# If empty, Django defaults to SQLite.
DB_NAME=music_player
DB_USER=music_user
DB_PASSWORD=music_password
DB_HOST=
DB_PORT=5432

# Set to True if you want to strictly enforce PostgreSQL
USE_POSTGRES=False

# YouTube API Key (Optional)
# If provided, enables official API search. If empty, uses keyless scraper.
YOUTUBE_API_KEY=
